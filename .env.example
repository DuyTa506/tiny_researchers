KAGGLE_KEY=

# === Storage ===
MONGODB_URI=mongodb://localhost:27017/claw_researcher
REDIS_URL=redis://localhost:6379/0

# === Experiment Tracking ===
MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# === Docker ===
DOCKER_HOST=unix:///var/run/docker.sock

# === App ===
CLAW_WORKSPACE=./workspace
CLAW_LOG_LEVEL=INFO
CLAW_DEFAULT_MODEL=claude-sonnet-4-6-20250827
CLAW_FAST_MODEL=claude-haiku-4-5-20251001
CLAW_DEEP_MODEL=claude-opus-4-6-20250826

