# === LLM Providers ===
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# === Research APIs ===
SEMANTIC_SCHOLAR_API_KEY=

# === Kaggle (used by dataset_download tool to generate download scripts) ===
KAGGLE_USERNAME=
KAGGLE_KEY=

# === Docker (required for Phase 2 reproduction tools) ===
DOCKER_HOST=unix:///var/run/docker.sock

# === App ===
CLAW_WORKSPACE=./workspace
CLAW_DEFAULT_MODEL=anthropic/claude-sonnet-4-20250514
CLAW_MAX_ITERATIONS=40
CLAW_CONTEXT_WINDOW_TOKENS=128000
CLAW_LOG_LEVEL=INFO
CLAW_DEBUG=false

# === Exec Tool ===
CLAW_EXEC_ENABLED=true
CLAW_EXEC_TIMEOUT=60

# === Interactive Channels ===
# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOW_FROM=*

# Discord
DISCORD_BOT_TOKEN=
DISCORD_ALLOW_FROM=

# Email (IMAP inbound + SMTP outbound)
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_ALLOW_FROM=

# Messenger (Facebook)
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_VERIFY_TOKEN=
MESSENGER_APP_SECRET=

# Zalo Official Account
ZALO_OA_ACCESS_TOKEN=
ZALO_APP_SECRET=

# Webhook server (Messenger + Zalo)
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080

# Groq (audio transcription, optional)
GROQ_API_KEY=
