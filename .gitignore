# ============================================================
# Claw Researcher — .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# --- Build / packaging ---
dist/
build/
*.egg-info/
*.egg
MANIFEST

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- uv ---
.uv/
uv.lock

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject

# --- OS ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# --- Environment / secrets ---
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# --- Workspace runtime data ---
workspace/
media/
data/
results/
checkpoints/
artifacts/

# --- Channel config (may contain tokens) ---
channels.json
**/channels.json

# --- Logs ---
*.log
logs/

# --- Database / storage ---
*.db
*.sqlite
*.sqlite3
mlruns/
mlflow.db
mlflow_data/

# --- Test / Coverage ---
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# --- Linting / type checking ---
.ruff_cache/
.mypy_cache/
.pytype/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- Reports / outputs (generated) ---
reports/
reproductions/
memory/

# --- Docker volumes (local bind-mounts) ---
mongo_data/
redis_data/
pgdata/

# --- Downloaded models / cache ---
.cache/
models/
*.bin
*.pt
*.ckpt
*.safetensors
